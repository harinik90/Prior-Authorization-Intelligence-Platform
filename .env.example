# ── Azure API Management (APIM) — Claude model gateway ───────────────────────
# All Claude agent calls route through APIM, never directly to api.anthropic.com
APIM_ENDPOINT=https://<your-apim-name>.azure-api.net/anthropic
APIM_SUBSCRIPTION_KEY=<your-apim-subscription-key>

# ── Claude Model ──────────────────────────────────────────────────────────────
# Optional — defaults to claude-sonnet-4-6 if not set
CLAUDE_MODEL=claude-sonnet-4-6

# ── Azure AI Foundry (Hosted Agent Service: Coverage Prediction, Submission) ──
# Project endpoint for AzureAIAgentClient (threads + runs model)
# Find in: AI Foundry portal → your project → Settings → Project details → Endpoint
# Format: https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
# Optional — defaults to gpt-4o if not set
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Healthcare Integrations (optional — mock used if absent) ──────────────────
# When PAYER_API_ENDPOINT is not set, submit_pa_to_payer() and poll_pa_status()
# return mock responses (status: pending / approved). Safe for development/testing.
PAYER_API_ENDPOINT=https://<payer-api-endpoint>
PAYER_API_KEY=<payer-api-key>

# ── Windows UTF-8 fix ─────────────────────────────────────────────────────────
PYTHONUTF8=1
